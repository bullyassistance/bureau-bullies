# ============================================================================
#  BUREAU BULLIES — Environment Variable Template
#  Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ---- Anthropic Claude API --------------------------------------------------
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY
CLAUDE_MODEL=claude-sonnet-4-6

# ---- GoHighLevel (GHL) API v2 ----------------------------------------------
# Generate at: Settings → API → Private Integrations (in your sub-account).
GHL_API_KEY=pit-REPLACE_WITH_REAL_PIT_TOKEN
GHL_LOCATION_ID=REPLACE_WITH_LOCATION_ID

# Workflow IDs per tier — copy from GHL after building each workflow.
GHL_WORKFLOW_TOOLKIT=
GHL_WORKFLOW_ACCELERATOR=
GHL_WORKFLOW_DFY=

# ---- Admin endpoint auth ---------------------------------------------------
# Long random string — protects every /admin/* route.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=REPLACE_WITH_RANDOM_32_BYTE_STRING

# ---- Owner notifications ---------------------------------------------------
# E.164 phone number that receives purchase + handoff alerts via SMS.
UMAR_NOTIFY_PHONE=+15555555555

# ---- Meta Graph API (Instagram direct webhook) -----------------------------
# Long-lived Page Access Token from a Meta app with the Instagram product
# enabled and instagram_business_manage_messages permission.
META_IG_PAGE_TOKEN=REPLACE_WITH_META_PAGE_TOKEN

# Shared secret used to verify Meta's webhook GET handshake.
# Must match what you configure in the Meta dev console webhook settings.
META_WEBHOOK_VERIFY_TOKEN=replace_with_random_verify_string

# Meta App Secret — used to verify X-Hub-Signature-256 on incoming webhook
# POSTs. Find under App Settings → Basic → App Secret.
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET

# ---- App behavior ----------------------------------------------------------
MAX_FILE_MB=25
MAX_REPORT_CHARS=180000
THANK_YOU_URL=/thank-you

# ---- Optional: bypass in-process Meta lead sweep ---------------------------
# Set to "0" to disable the every-60s scheduler tick that calls
# /admin/sync-fb-leads via 127.0.0.1. Leave unset (or set to "1") for default.
BB_AUTO_META_SWEEP=1
